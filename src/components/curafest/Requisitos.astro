                <!-- Decoración fondo -->
                <div class="absolute -right-6 -top-6 text-ale-purple/10 transform rotate-12">
                    <svg class="w-40 h-40" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                </div>
                
                <div class="relative z-10">
                    <h3 class="text-2xl md:text-3xl font-black text-ale-purple mb-2 text-center md:text-left">📋 Requisitos para Ganar</h3>
                    <p class="text-gray-600 mb-8 font-medium text-center md:text-left">
