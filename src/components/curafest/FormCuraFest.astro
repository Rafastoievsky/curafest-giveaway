---
import AgreeSubmit from "./formItems/AgreeSubmit";


---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="md:col-span-2">
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Nombre(s)</label
    >
    <input
      type="text"
      name="nombre"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      placeholder="Ej. María Fernanda"
    />
  </div>
  <div>
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Apellido Paterno</label
    >
    <input
      type="text"
      name="apaterno"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      placeholder="López"
    />
  </div>
  <div>
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Apellido Materno</label
    >
    <input
      type="text"
      name="amaterno"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      placeholder="Pérez"
    />
  </div>

  <div>
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Celular (10 dígitos)</label
    >
    <input
      type="tel"
      name="celular"
      pattern="[0-9]{10}"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      placeholder="662..."
    />
  </div>
  <div>
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Correo Electrónico</label
    >
    <input
      name="email"
      type="email"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      placeholder="tu@correo.com"
    />
  </div>

  <!-- NUEVO CAMPO: Localidad -->
  <div class="md:col-span-2">
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Localidad</label
    >
    <select
      name="poblacion"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white text-gray-700"
    >
      <option value="" disabled selected>Selecciona tu localidad</option>
      <option value="Hermosillo">Hermosillo</option>
      <option value="Bahia de Kino">Bahía de Kino</option>
      <option value="Poblado Miguel Aleman">Poblado Miguel Alemán (PMA)</option>
      <option value="San Pedro">San Pedro El Saucito</option>
      <option value="La Victoria">La Victoria</option>
      <option value="El Tazajal">El Tazajal</option>
      <option value="Molino de Camou">Molino de Camou</option>
      <option value="Alejandro Carrillo Marcor">Alejandro Carrillo Marcor</option>
      <option value="Zamora">Zamora</option>
      <option value="El Tronconal">El Tronconal</option>
    </select>
  </div>

  <div class="md:col-span-2">
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >Colonia</label
    >
    <input
      type="text"
      name="colonia"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      placeholder="Ej. San Benito"
    />
  </div>
  <div class="md:col-span-2 grid grid-cols-3 gap-4">
    <div class="col-span-2">
      <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
        >Calle</label
      >
      <input
        type="text"
        name="calle"
  
        class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      />
    </div>
    <div>
      <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
        >Número</label
      >
      <input
        type="text"
        name="num_ext"
  
        class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white"
      />
    </div>
  </div>
  <input type="hidden" name="giveaway_name" value="chayanne2026">


  <!-- NUEVO CAMPO: Cómo se enteró -->
  <div class="md:col-span-2 mt-2">
    <label class="block text-ale-purple font-bold mb-2 text-sm uppercase"
      >¿Cómo te enteraste del sorteo?</label
    >
    <select
      name="comoseentero"

      class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-ale-pink focus:ring-0 outline-none transition-colors bg-white text-gray-700"
    >
      <option value="" disabled selected>Elige una opción</option>
      <option value="facebook">Facebook</option>
      <option value="instagram">Instagram</option>
      <option value="pagina_web">Pagina Web</option>
      <option value="youtube">YouTube</option>
      <option value="amigo_amiga">Me comentó una amiga/amigo</option>
    </select>
  </div>





</div>
<AgreeSubmit client:only="react" />


