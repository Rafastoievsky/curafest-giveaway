---
import { Picture } from "astro:assets";
import Requisitos from "../curafest/Requisitos.astro";
import aln from "@/assets/images/aln.png";

import heroBg from "@/assets/images/diamadres-hero.png";
import bottomBg from "@/assets/images/diamadres-bottom.png";
---

<div class="max-w-350 mx-auto px-4 pb-12">
  <section class="overflow-hidden rounded-[30px] md:rounded-[50px] shadow-2xl bg-[#a3479b]">

    <!-- HERO -->
    <div class="relative min-h-155 md:min-h-195 lg:min-h-270 overflow-hidden">
      <!-- imagen hero -->
      <Picture
        src={heroBg}
        alt="Giveaway Grupo Firme Día de las Madres"
        width={1600}
        height={1260}
        class="absolute inset-0 h-full w-full object-cover object-[70%_top] md:object-[72%_top] lg:object-center"
        formats={["avif", "webp"]}
      />

      <!-- overlays -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#cdbed8]/80 via-[#d9bfdc]/30 to-transparent md:from-[#cdbed8]/68 md:via-[#d9bfdc]/14 md:to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-b from-transparent to-[#a3479b]/35"></div>

      <!-- contenido -->
      <div class="relative z-10 px-6 pt-6 md:px-10 md:pt-10 lg:px-14 lg:pt-12">
        <div class="flex items-center gap-2 mb-6">
          <div class="relative shrink-0">
            <Picture
              src={aln}
              alt="Alejandra López Noriega"
              width={100}
              height={100}
              class="size-16 md:size-24 rounded-full border-4 border-white shadow-lg object-cover"
              formats={["avif", "webp"]}
            />
          </div>

          <div class="bg-white px-4 py-2 rounded-2xl rounded-tl-none shadow-md">
            <p class="font-hand text-[#e91e63] font-bold text-sm md:text-base">
              ¡Hola, te invito a participar!
            </p>
          </div>
        </div>

        <div class="w-full md:w-1/2 lg:w-[55%] text-left pr-4 md:pr-8 lg:pr-12">
          <h2 class="text-yellow-400 font-black text-3xl md:text-5xl uppercase italic drop-shadow-md">
            GANA
          </h2>

          <h1 class="text-white font-black uppercase leading-[0.88] mb-4">
            <span class="block text-4xl md:text-6xl lg:text-7xl tracking-tight">2 BOLETOS</span>
            <span class="block text-yellow-400 text-3xl md:text-5xl my-2 italic">PARA</span>
            <span class="block text-white text-5xl md:text-7xl lg:text-[5.3rem] tracking-tight">GRUPO</span>
            <span class="block text-white text-5xl md:text-7xl lg:text-[5.3rem] tracking-tight">FIRME</span>
          </h1>

          <div class="flex items-center gap-2 text-white font-bold text-lg md:text-2xl mb-8">
            <span>💰 SORTEO: 7 DE MAYO</span>
          </div>

          <a
            href="#registro"
            class="inline-block bg-gradient-to-r from-yellow-300 to-orange-500 text-purple-900 font-black py-4 px-10 rounded-full shadow-xl transform transition hover:scale-105 active:scale-95 text-lg md:text-xl uppercase"
          >
            ¡QUIERO MIS BOLETOS! »
          </a>
        </div>
      </div>
    </div>

    <!-- REQUISITOS -->
    <div class="relative overflow-hidden -mt-2" id="registro">
      <Picture
        src={bottomBg}
        alt="Fondo sección requisitos"
        width={1600}
        height={960}
        class="absolute inset-0 h-full w-full object-cover object-top"
        formats={["avif", "webp"]}
      />

      <div class="absolute inset-0 bg-[#a3479b]/30"></div>

      <div class="flex justify-center z-10 px-6 py-8 md:px-10 md:py-10 lg:px-14 lg:py-14">
        <div class="w-3/4 rounded-[28px] bg-white/92 p-3 shadow-2xl backdrop-blur-sm">
          <Requisitos />
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  :global(body) {
    font-family: "Montserrat", sans-serif;
    background: linear-gradient(135deg, #7e22ce 0%, #a855f7 50%, #d946ef 100%);
  }
</style>

