---
import Navbar from "../components/curafest/ui/Navbar.astro";
import Footer from "../components/curafest/Footer.astro";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

// Valores por defecto (Fallback)
const { 
	title = "¡Gana Boletos VIP para Chayanne!",
	description = "¿Quieres ver a Chayanne en Zona VIP? Participa GRATIS en el Gran Sorteo de la Diputada Alejandra López Noriega. Exclusivo para residentes de Hermosillo.",
	image = "/images/chayanneGiveaway.png" 
} = Astro.props;

// Obtener la URL completa actual para el canonical y Open Graph
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const imageURL = new URL(image, Astro.url.origin).toString();

---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />

		<!-- ============================================ -->
		<!-- SEO BÁSICO -->
		<!-- ============================================ -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="Sorteo Alejandra López Noriega, Boletos Chayanne Gratis, en Hermosillo, Giveaway Hermosillo,Sonora, Diputada Alejandra, Boletos VIP Chayanne">
		<meta name="author" content="Alejandra López Noriega">
		<meta name="robots" content="index, follow">

		<!-- ============================================ -->
		<!-- OPEN GRAPH (Facebook, WhatsApp, LinkedIn) -->
		<!-- ============================================ -->
		<meta property="og:type" content="website">
		<meta property="og:url" content={canonicalURL}>
		<meta property="og:title" content={title}>
		<meta property="og:description" content={description}>
		<meta property="og:image" content={imageURL}>
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta property="og:locale" content="es_MX">
		<meta property="og:site_name" content="Sorteo Alejandra López Noriega">

		<!-- ============================================ -->
		<!-- TWITTER CARDS (X) -->
		<!-- ============================================ -->
		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:title" content={title}>
		<meta name="twitter:description" content={description}>
		<meta name="twitter:image" content={imageURL}>

    <title>ALN Giveaway Chayanne</title>
    		<!-- ============================================ -->
		<!-- FACEBOOK PIXEL CODE -->
		<!-- ============================================ -->
		<script is:inline>
      /* @ts-ignore */
      (function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)})(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      
      // ⚠️ REEMPLAZA 'TU-ID-DE-PIXEL' CON TU NÚMERO REAL ⚠️
      /* @ts-ignore */
      fbq('init', '594433199218146'); 
      /* @ts-ignore */
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=TU-ID-DE-PIXEL&ev=PageView&noscript=1"
    /></noscript>
      <!-- End Facebook Pixel Code -->

  </head>
  
  <body
    class="bg-texture text-gray-800 font-sans antialiased overflow-x-hidden"
  >
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style>
  /* Patrón sutil de ruido para efecto papel */
  .bg-texture {
    background-color: #f9f7f2;
    background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM12 86c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm28-65c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm23-11c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-6 60c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm29 22c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zM32 63c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm57-13c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-9-21c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM60 91c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM35 41c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 60c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%239C92AC' fill-opacity='0.05' fill-rule='evenodd'/%3E%3C/svg%3E");
  }

  /* Animación suave para el botón */
  .btn-hover {
    transition: all 0.3s ease;
  }
  .btn-hover:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(255, 87, 34, 0.4);
  }

  /* Estilo personalizado para selects */
  select {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%234A148C' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
  }
</style>
